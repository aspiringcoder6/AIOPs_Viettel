# Database
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=aiops
POSTGRES_PORT=5433

# LLM providers
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_API_URL=https://api.groq.com/openai/v1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# App ports
NODE_API_PORT=3000
PROMETHEUS_PORT=9090
CADVISOR_PORT=8080
NGINX_PORT=80
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601
DASHBOARD_API_PORT=3100
DASHBOARD_PORT=5173
DASHBOARD_ORIGIN=http://localhost:5173
DASHBOARD_API_PUBLIC_URL=http://localhost:3100/api

# Detector behavior
EVENT_COOLDOWN_SECONDS=120

# Context Builder behavior
CONTEXT_WINDOW_MINUTES=5
CONTEXT_LOG_SEARCH_SIZE=250
CONTEXT_MAX_LOGS=80

# Resource limits for local development
POSTGRES_CPUS=0.75
POSTGRES_MEMORY=768m
REDIS_CPUS=0.25
REDIS_MEMORY=256m
PROMETHEUS_CPUS=0.50
PROMETHEUS_MEMORY=512m
CADVISOR_CPUS=0.35
CADVISOR_MEMORY=384m
NGINX_CPUS=0.25
NGINX_MEMORY=128m
ELASTICSEARCH_CPUS=1.00
ELASTICSEARCH_MEMORY=1g
ELASTICSEARCH_JAVA_OPTS=-Xms384m -Xmx384m
KIBANA_CPUS=0.50
KIBANA_MEMORY=512m
NODE_API_CPUS=0.50
NODE_API_MEMORY=512m
COLLECTOR_CPUS=0.35
COLLECTOR_MEMORY=384m
DETECTOR_CPUS=0.35
DETECTOR_MEMORY=384m
CONTEXT_BUILDER_CPUS=0.35
CONTEXT_BUILDER_MEMORY=384m
AGENT_CPUS=0.35
AGENT_MEMORY=384m
ALERT_MANAGER_CPUS=0.25
ALERT_MANAGER_MEMORY=256m
CLI_CPUS=0.25
CLI_MEMORY=256m
DASHBOARD_API_CPUS=0.35
DASHBOARD_API_MEMORY=384m
DASHBOARD_CPUS=0.35
DASHBOARD_MEMORY=384m
