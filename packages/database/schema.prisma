generator client{
    provider = "prisma-client-js"
}
enum EVENT_TYPE{
    SERVICE_DOWN
    LATENCY_SPIKE
    ERROR_SPIKE
    CPU_SPIKE
    MEMORY_SPIKE
    DISK_FULL
    CONNECTION_FAILURE
}
enum INCIDENT_STATUS{
    OPEN
    ACKNOWLEDGED
    INVESTIGATING
    RESOLVED
    CLOSED
}
model Service{
    id UUID @id @default(uuid())
    name String @unique
    service_type String
    environment String 
    status String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
model ServiceDependencies{
    service_id UUID @id @default(uuid())
    dependency_id UUID @id @default(uuid())
    service Service @relation(fields: [service_id], references: [id])
    dependency Service @relation(fields: [dependency_id], references: [id])
}
model Events{
    id UUID @id @default(uuid())
    event_type EVENT_TYPE
    service_id UUID
    detected_at DateTime @default(now())
    severity String
    status String
    metadata JSON
    service Service @relation(fields: [service_id], references: [id])
}
model ContextBundle{
    id UUID @id @default(uuid())
    event_id UUID
    start_time DateTime @default(now())
    end_time DateTime?
    affected_services JSON
    summary String
    createdAt DateTime @default(now())
    event Events @relation(fields: [event_id], references: [id])
}
model Incident{
    id UUID @id @default(uuid())
    event_id UUID
    context_bundle_id UUID
    severity String
    root_cause String
    confidence FLOAT
    status INCIDENT_STATUS
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    contextBundle ContextBundle @relation(fields: [context_bundle_id], references: [id])
    event Events @relation(fields: [event_id], references: [id])
}
model AI_ANALYSIS{
    id UUID @id @default(uuid())
    incident_id UUID
    provider String
    model String
    prompt String
    response String
    tokens_used Int
    createdAt DateTime @default(now())
    incident Incident @relation(fields: [incident_id], references: [id])
}
model recommendations{
    id UUID @id @default(uuid())
    incident_id UUID
    recommendation String
    priority INT
    executed Boolean @default(false)
    createdAt DateTime @default(now())
    incident Incident @relation(fields: [incident_id], references: [id])
}
model alerts{
    id UUID @id @default(uuid())
    incident_id UUID
    channel String
    status String
    recipient String
    message String
    sent_at DateTime @default(now())
    seen_at DateTime?
    incident Incident @relation(fields: [incident_id], references: [id])
}
model chat_sessions{
    id UUID @id @default(uuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    incident Incident @relation(fields: [incident_id], references: [id])
}
model chat_messages{
    id UUID @id @default(uuid())
    session_id UUID
    role String
    message String
    timestamp DateTime @default(now())
    chat_sessions chat_sessions @relation(fields: [session_id], references: [id])
}